# Staging environment file
# Copy to backend/.env.stg and fill all required values.

NODE_ENV=staging
PORT=3000

# Use a separate staging database from production
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<staging_db_name>?retryWrites=true&w=majority

# Redis is injected by docker-compose.stg.yml as redis://redis-stg:6379
REDIS_URL=redis://redis-stg:6379
REDIS_TLS=false

# Use different secrets from production
JWT_SECRET=replace-with-long-random-secret
REFRESH_SECRET=replace-with-long-random-secret
SUPER_ADMIN_SECRET=replace-with-strong-secret

# Only staging domains here
CORS_ORIGINS=https://stg-admin.example.com

# Keep same values as production where needed
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_DEV_ECHO=false
RESERVATION_TTL_SECONDS=900

CACHE_PREFIX=tagadod-stg:
CACHE_TTL=3600
CACHE_ENABLED=true

LOG_LEVEL=info
DISABLE_THREAT_DETECTION=false

# External providers (set staging or sandbox credentials)
BUNNY_STORAGE_ZONE=
BUNNY_API_KEY=
BUNNY_HOSTNAME=storage.bunnycdn.com
BUNNY_CDN_HOSTNAME=

WA_BASE_URL=
WA_API_KEY=
WA_INSTANCE_NAME=tagdod_staging
WA_INSTANCE_TOKEN=
WAHA_BASE_URL=
WAHA_API_KEY=

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

FCM_PROJECT_ID=
FCM_PRIVATE_KEY_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=
FCM_CLIENT_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

SMS_PROVIDER=alawael
ALAWAEL_SMS_ORG_NAME=
ALAWAEL_SMS_USER_NAME=
ALAWAEL_SMS_PASSWORD=
ALAWAEL_SMS_BASE_URL=https://sms.alawaeltec.com

# Tejo / Gemini
TEJO_ENABLED=true
TEJO_WEB_PILOT_ENABLED=false
TEJO_PROVIDER_ORDER=gemini,provider-a,provider-b
TEJO_HANDOFF_THRESHOLD=0.55
TEJO_GEMINI_API_KEY=
TEJO_GEMINI_CHAT_MODEL=gemini-2.0-flash
TEJO_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
TEJO_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
